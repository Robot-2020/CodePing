{
  "schemaVersion": 1,
  "name": "Ellen Swallow",
  "author": "User",
  "version": "1.0.0",
  "description": "A cute round character with pink and orange warm sunset colors decoration",
  "license": "MIT",
  "viewBox": {
    "x": -20,
    "y": -25,
    "width": 55,
    "height": 55
  },
  "layout": {
    "contentBox": {
      "x": -8,
      "y": -8,
      "width": 32,
      "height": 32
    },
    "marginBox": {
      "x": -12,
      "y": -12,
      "width": 40,
      "height": 40
    },
    "centerX": 8,
    "baselineY": 24,
    "visibleHeightRatio": 0.6,
    "baselineBottomRatio": 0.05
  },
  "eyeTracking": {
    "enabled": true,
    "states": [
      "idle",
      "dozing",
      "mini-idle"
    ],
    "eyeRatioX": 0.5,
    "eyeRatioY": 0.5,
    "maxOffset": 2,
    "bodyScale": 0.2,
    "shadowStretch": 0.1,
    "shadowShift": 0.2,
    "ids": {
      "eyes": "eyes-js",
      "body": "body-js",
      "shadow": "shadow-js",
      "dozeEyes": "eyes-doze"
    },
    "shadowOrigin": "8px 22px"
  },
  "states": {
    "idle": [
      "sunset-working-conducting.svg"
    ],
    "yawning": [
      "sunset-idle-yawn.svg"
    ],
    "dozing": [
      "sunset-idle-doze.svg"
    ],
    "collapsing": [
      "sunset-collapse-sleep.svg"
    ],
    "thinking": [
      "sunset-working-thinking.svg"
    ],
    "working": [
      "sunset-working-typing.svg"
    ],
    "juggling": [
      "sunset-working-juggling.svg"
    ],
    "sweeping": [
      "sunset-working-sweeping.svg"
    ],
    "error": [
      "sunset-error.svg"
    ],
    "attention": [
      "sunset-happy.svg"
    ],
    "notification": [
      "sunset-notification.svg"
    ],
    "carrying": [
      "sunset-working-carrying.svg"
    ],
    "sleeping": [
      "sunset-sleeping.svg"
    ],
    "waking": [
      "sunset-wake.svg"
    ]
  },
  "workingTiers": [
    {
      "minSessions": 3,
      "file": "sunset-working-building.svg"
    },
    {
      "minSessions": 2,
      "file": "sunset-working-juggling.svg"
    },
    {
      "minSessions": 1,
      "file": "sunset-working-typing.svg"
    }
  ],
  "jugglingTiers": [
    {
      "minSessions": 2,
      "file": "sunset-working-conducting.svg"
    },
    {
      "minSessions": 1,
      "file": "sunset-working-juggling.svg"
    }
  ],
  "idleAnimations": [
    {
      "file": "sunset-idle-look.svg",
      "duration": 6500
    },
    {
      "file": "sunset-idle-reading.svg",
      "duration": 14000
    }
  ],
  "displayHintMap": {
    "sunset-working-building.svg": "sunset-working-building.svg",
    "sunset-working-typing.svg": "sunset-working-typing.svg",
    "sunset-working-juggling.svg": "sunset-working-juggling.svg",
    "sunset-working-conducting.svg": "sunset-working-conducting.svg",
    "sunset-idle-reading.svg": "sunset-idle-reading.svg",
    "sunset-working-thinking.svg": "sunset-working-thinking.svg"
  },
  "timings": {
    "minDisplay": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 5500,
      "notification": 2500,
      "carrying": 3000,
      "working": 1000,
      "thinking": 1000
    },
    "autoReturn": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 300000,
      "notification": 2500,
      "carrying": 3000
    },
    "yawnDuration": 3000,
    "wakeDuration": 1500,
    "deepSleepTimeout": 600000,
    "mouseIdleTimeout": 20000,
    "mouseSleepTimeout": 60000
  },
  "hitBoxes": {
    "default": {
      "x": -4,
      "y": 0,
      "w": 24,
      "h": 24
    },
    "sleeping": {
      "x": -2,
      "y": 6,
      "w": 20,
      "h": 14
    },
    "wide": {
      "x": -6,
      "y": -2,
      "w": 28,
      "h": 28
    }
  },
  "wideHitboxFiles": [
    "sunset-error.svg",
    "sunset-notification.svg",
    "sunset-working-conducting.svg"
  ],
  "sleepingHitboxFiles": [
    "sunset-sleeping.svg",
    "sunset-collapse-sleep.svg"
  ],
  "reactions": {
    "drag": {
      "file": "sunset-react-drag.svg"
    },
    "clickLeft": {
      "file": "sunset-react-left.svg",
      "duration": 2500
    },
    "clickRight": {
      "file": "sunset-react-right.svg",
      "duration": 2500
    },
    "annoyed": {
      "file": "sunset-react-annoyed.svg",
      "duration": 3500
    },
    "double": {
      "files": [
        "sunset-react-double.svg",
        "sunset-react-double-jump.svg"
      ],
      "duration": 3500
    }
  },
  "miniMode": {
    "supported": true,
    "offsetRatio": 0.5,
    "states": {
      "mini-idle": [
        "sunset-mini-idle.svg"
      ],
      "mini-alert": [
        "sunset-mini-alert.svg"
      ],
      "mini-happy": [
        "sunset-mini-happy.svg"
      ],
      "mini-enter": [
        "sunset-mini-enter.svg"
      ],
      "mini-peek": [
        "sunset-mini-peek.svg"
      ],
      "mini-working": [
        "sunset-mini-typing.svg"
      ],
      "mini-crabwalk": [
        "sunset-mini-walk.svg"
      ],
      "mini-enter-sleep": [
        "sunset-mini-enter-sleep.svg"
      ],
      "mini-sleep": [
        "sunset-mini-sleep.svg"
      ]
    },
    "timings": {
      "minDisplay": {
        "mini-alert": 4000,
        "mini-happy": 4000
      },
      "autoReturn": {
        "mini-alert": 4000,
        "mini-happy": 4000
      }
    },
    "glyphFlips": {
      "pixel-z": 4,
      "pixel-z-small": 3
    }
  },
  "sounds": {
    "complete": "complete.mp3",
    "confirm": "confirm.mp3"
  },
  "objectScale": {
    "widthRatio": 1.6,
    "heightRatio": 1.2,
    "offsetX": -0.4,
    "offsetY": -0.2
  }
}
